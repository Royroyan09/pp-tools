<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Pile" Height="680" Width="1060" MinHeight="540" MinWidth="900"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        WindowState="Maximized"
        Background="#F3F5F8" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#174FAD"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF9800"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush1" Color="#E1E5EB"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#D64545"/>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF0F3"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="RowHeight" Value="30"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="66"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ===================== HEADER ===================== -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21"
                        Background="White" VerticalAlignment="Center">
                    <Image x:Name="imgLogo" Width="32" Height="32" Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="Auto Pile" Foreground="White" FontSize="17" FontWeight="SemiBold"/>
                    <TextBlock Text="Round and square concrete piles generated from a CAD drawing" Foreground="#CFE0F7" FontSize="11.5"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="lblDocTitle" Text="Document" Foreground="White" FontSize="12.5"
                               HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    <TextBlock Text="Revit Model" Foreground="#CFE0F7" FontSize="11" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== BODY ===================== -->
        <Grid Grid.Row="1" Margin="16,14,16,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== SOURCE ===== -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CAD SOURCE" Style="{StaticResource SectionLabel}"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="CAD import" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="1" x:Name="cmbCadImport" DisplayMemberPath="Display"/>

                        <TextBlock Grid.Column="3" Text="Perimeter layer" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="4" x:Name="cmbPerimLayer" DisplayMemberPath="Display"/>
                        <Button Grid.Column="5" x:Name="btnPickPerim" Content="Pick Layer" Style="{StaticResource SecondaryButton}"/>

                        <TextBlock Grid.Column="7" x:Name="lblLabelLayer" Text="Label layer" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="8" x:Name="cmbLabelLayer" DisplayMemberPath="Display"/>
                        <Button Grid.Column="9" x:Name="btnPickLabel" Content="Pick Label" Style="{StaticResource SecondaryButton}"/>

                        <Button Grid.Column="11" x:Name="btnApply" Content="Apply" Style="{StaticResource PrimaryButton}" Width="100"/>
                    </Grid>

                    <CheckBox Grid.Row="2" x:Name="chkNoLabels" Margin="0,10,0,0" VerticalContentAlignment="Center"
                              Content="No labels in this CAD — group piles purely by Diameter / Width x Length (skips label layer/matching entirely)"/>

                    <TextBlock Grid.Row="3" x:Name="lblInfo" Margin="0,10,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5"
                               Text="Click 'Pick Layer' and pick one pile (circle, closed polyline, or block) in the drawing, then 'Pick Label' and pick a nearby pile/cap label. Apply reads every circle/polyline/block on the perimeter layer, sizes it, and matches it to CAD text — a pile with no trustworthy nearby label gets a size-derived name instead of borrowing an unrelated one."/>
                </Grid>
            </Border>

            <!-- ===== TYPES ===== -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="PILE TYPES (one per unique label — review sizes, fill Depth)" Style="{StaticResource SectionLabel}"/>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Depth" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1" x:Name="txtBatchDepth"/>
                        <Button Grid.Column="2" x:Name="btnBatchFillDepth" Content="Fill Selected Rows"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Select rows in the grid below (Ctrl/Shift-click), type a Depth above, then click this to fill it into every selected row at once."/>
                    </Grid>

                    <DataGrid x:Name="dgTypes" Grid.Row="2">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Use" Binding="{Binding Include, Mode=TwoWay}" Width="40"/>
                            <DataGridTextColumn Header="Type (label)" Binding="{Binding Label}" IsReadOnly="True" Width="110"/>
                            <DataGridTextColumn Header="Piles" Binding="{Binding Count}" IsReadOnly="True" Width="60"/>
                            <DataGridTextColumn Header="Shape" Binding="{Binding Shape}" IsReadOnly="True" Width="80"/>
                            <DataGridTextColumn x:Name="colSize1" Header="Diameter / Width" Binding="{Binding Size1, Mode=TwoWay}" Width="120"/>
                            <DataGridTextColumn x:Name="colSize2" Header="Length (if not square)" Binding="{Binding Size2, Mode=TwoWay}" Width="140"/>
                            <DataGridTextColumn x:Name="colDepth" Header="Depth" Binding="{Binding Depth, Mode=TwoWay}" Width="110"/>
                            <DataGridTextColumn Header="Named via" Binding="{Binding NamedVia}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" IsReadOnly="True" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ===== PLACEMENT ===== -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Base level" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbLevel" DisplayMemberPath="Display"/>
                    <TextBlock Grid.Column="3" x:Name="lblFamilyInfo" TextWrapping="Wrap" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5"
                               Text="Piles are placed with their TOP flush with the selected level; depth extends downward."/>
                </Grid>
            </Border>
        </Grid>

        <!-- ===================== FOOTER ===================== -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush1}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="lblStatus" Text="Ready." VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnClose" Content="Close" Style="{StaticResource SecondaryButton}" Width="90"/>
                    <Button x:Name="btnGenerate" Content="Generate Piles" Style="{StaticResource PrimaryButton}" Width="150"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
