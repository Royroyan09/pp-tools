<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TyPPe Manager" Height="780" Width="1200" MinHeight="620" MinWidth="1000"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        Background="#F3F5F8" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#174FAD"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#123F8C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF9800"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F3F5F8"/>
        <SolidColorBrush x:Key="BorderBrush1" Color="#E1E5EB"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#D64545"/>

        <!-- Flat button base -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF0F3"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="RowHeight" Value="30"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Padding" Value="2,3"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="66"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ===================== HEADER ===================== -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21"
                        Background="White" VerticalAlignment="Center">
                    <Image x:Name="imgLogo" Width="32" Height="32" Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="TyPPe Manager" Foreground="White" FontSize="17" FontWeight="SemiBold"/>
                    <TextBlock Text="Family type &amp; compound structure editor" Foreground="#CFE0F7" FontSize="11.5"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="lblDocTitle" Text="Document" Foreground="White" FontSize="12.5"
                               HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    <TextBlock Text="Revit Model" Foreground="#CFE0F7" FontSize="11" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== TOOLBAR ===================== -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush1}" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Category" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" x:Name="cmbCategory" DisplayMemberPath="Display" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3" Text="Search" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="4" x:Name="txtSearch" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Button x:Name="btnRefresh" Content="Refresh" Style="{StaticResource SecondaryButton}"/>
                    <Button x:Name="btnNewType" Content="New Type" Style="{StaticResource SecondaryButton}"/>
                    <Button x:Name="btnDuplicate" Content="Duplicate" Style="{StaticResource SecondaryButton}"/>
                    <Button x:Name="btnRename" Content="Rename" Style="{StaticResource SecondaryButton}"/>
                    <Button x:Name="btnDelete" Content="Delete" Style="{StaticResource DangerButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== MAIN CONTENT ===================== -->
        <Grid Grid.Row="2" Margin="16,14,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*" MinWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Type tree -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Text="FAMILIES &amp; TYPES" Style="{StaticResource SectionLabel}"/>
                    <TreeView x:Name="treeTypes" BorderThickness="0" Background="Transparent"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- RIGHT: details -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock x:Name="lblSelectedType" Text="Select a type from the list"
                                   FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="lblSelectedSub" Text="No type selected"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <TabControl Grid.Row="1" x:Name="tabDetails" BorderThickness="0" Background="Transparent">

                        <TabItem x:Name="tabStructureItem" Header="Structure (Layers)">
                            <DockPanel Margin="0,10,0,0">
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <Button x:Name="btnAddLayer" Content="+ Add Layer" Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"/>
                                        <Button x:Name="btnRemoveLayer" Content="Remove Layer" Style="{StaticResource SecondaryButton}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" x:Name="lblTotalThickness" Text="Total thickness: -"
                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Grid>

                                <DataGrid x:Name="dgLayers" ItemsSource="{Binding}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Index}" IsReadOnly="True" Width="34"/>
                                        <DataGridComboBoxColumn x:Name="colFunction" Header="Function"
                                                                 SelectedItemBinding="{Binding Function, Mode=TwoWay}" Width="130"/>
                                        <DataGridComboBoxColumn x:Name="colMaterial" Header="Material"
                                                                 SelectedItemBinding="{Binding MaterialName, Mode=TwoWay}" Width="*"/>
                                        <DataGridTextColumn x:Name="colThickness" Header="Thickness"
                                                             Binding="{Binding Thickness, Mode=TwoWay}" Width="110"/>
                                        <DataGridCheckBoxColumn Header="Core" Binding="{Binding IsCore}" IsReadOnly="True" Width="46"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </TabItem>

                        <TabItem Header="Type Parameters">
                            <DataGrid x:Name="dgParameters" Margin="0,10,0,0" ItemsSource="{Binding}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Parameter" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay}" Width="260"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <!-- ===================== FOOTER ===================== -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrush1}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="lblStatus" Text="Ready." VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnCancel" Content="Close" Style="{StaticResource SecondaryButton}" Width="90"/>
                    <Button x:Name="btnSave" Content="Save Changes" Style="{StaticResource PrimaryButton}" Width="130"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
